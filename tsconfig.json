{
  "compilerOptions": {
    "lib": [
      "ES2018"
    ],
    "strict": true,
    "checkJs": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "rootDir": "src",
    "declarationDir": "dist",
    "declaration": true,
    "emitDeclarationOnly": true,
    "skipLibCheck": true
  },
  "include": [
    "src"
  ]
}
