{
  "name": "@bpmn-io/semver-compat",
  "version": "0.1.0",
  "description": "Check whether provided semver versions satisfy required ranges",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bpmn-io/semver-compat.git"
  },
  "author": "bpmn.io contributors",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bpmn-io/semver-compat/issues"
  },
  "homepage": "https://github.com/bpmn-io/semver-compat#readme",
  "scripts": {
    "all": "run-s lint build check-types test",
    "build": "rollup -c",
    "test": "mocha --recursive test",
    "lint": "eslint .",
    "prepare": "run-s build",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "semver": "^7.7.2"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@types/chai": "^5.0.0",
    "@types/mocha": "^10.0.0",
    "@types/semver": "^7.0.0",
    "chai": "^6.2.2",
    "eslint": "^9.0.0",
    "eslint-plugin-bpmn-io": "^2.0.0",
    "mocha": "^11.0.0",
    "npm-run-all2": "^8.0.0",
    "rollup": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
