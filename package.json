{
  "name": "@bpmn-io/semver-compat",
  "version": "0.1.0",
  "description": "Check whether provided engine versions satisfy semver requirements",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "all": "run-s lint build check-types test",
    "build": "rollup -c --bundleConfigAsCjs",
    "test": "mocha --recursive test",
    "lint": "eslint .",
    "prepare": "run-s build",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@types/chai": "^5.0.0",
    "@types/mocha": "^10.0.0",
    "@types/semver": "^7.0.0",
    "chai": "^5.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-bpmn-io": "^2.0.0",
    "mocha": "^11.0.0",
    "npm-run-all2": "^8.0.0",
    "rollup": "^4.0.0",
    "semver": "^7.7.2",
    "typescript": "^5.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bpmn-io/semver-compat.git"
  },
  "author": "bpmn.io contributors",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bpmn-io/semver-compat/issues"
  },
  "homepage": "https://github.com/bpmn-io/semver-compat#readme"
}
